{
  "expo": {
    "name": "folders-app",
    "slug": "folders-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "foldersapp",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "ios": {
      "bundleIdentifier": "com.sknk.foldersapp",
      "supportsTablet": false,
      "entitlements": {
        "com.apple.security.application-groups": ["group.com.sknk.foldersapp"]
      }
    },
    "android": {
      "package": "com.sknk.foldersapp"
    },
    "plugins": [
      "expo-sqlite",
      "expo-web-browser",
      [
        "expo-share-extension",
        {
          "activationRules": [
            { "type": "url", "max": 1 }
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "df21cc8c-6420-4d64-86d5-07d76249ab28"
      }
    },
    "owner": "sknk-aaa"
  }
}
