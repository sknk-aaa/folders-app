{
  "expo": {
    "name": "Bookrest",
    "slug": "folders-app",
    "version": "1.3.0",
    "orientation": "portrait",
    "scheme": "foldersapp",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "ios": {
      "bundleIdentifier": "com.sknk.foldersapp",
      "buildNumber": "22",
      "supportsTablet": false,
      "icon": "./assets/icon.png",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.sknk.foldersapp"
        ]
      },
      "infoPlist": {
        "AppGroup": "group.com.sknk.foldersapp",
        "NSPhotoLibraryUsageDescription": "We use your photo library so you can choose thumbnail images for your folders."
      }
    },
    "android": {
      "package": "com.sknk.foldersapp"
    },
    "locales": {
      "ja": "./assets/locales/ja.json",
      "en": "./assets/locales/en.json"
    },
    "plugins": [
      "expo-sqlite",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/splash.png",
          "imageWidth": 280,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-share-extension",
        {
          "preprocessingFile": "./preprocessing.js"
        }
      ],
      [
        "react-native-cloud-storage",
        {
          "iCloudContainerEnvironment": "Production",
          "iCloudContainerIdentifier": "iCloud.com.sknk.foldersapp"
        }
      ],
      "expo-video",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "df21cc8c-6420-4d64-86d5-07d76249ab28"
      }
    },
    "owner": "sknk-aaa"
  }
}
