default_platform(:ios)

APP_ID = "com.sknk.foldersapp"
EXT_ID = "com.sknk.foldersapp.ShareExtension"
SCHEME = "Bookrest"
EXT_TARGET = "BookrestShareExtension"

platform :ios do
  # CI環境では一時キーチェーンを作成・解錠（codesignのUIダイアログ待ちハングを防ぐ）
  before_all do
    setup_ci if ENV["CI"]
  end

  def asc_api_key
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: ENV["ASC_API_KEY_PATH"],
      in_house: false
    )
  end

  def project_root
    File.expand_path("..", __dir__)
  end

  # CocoaPodsが ios/Bookrest.xcworkspace を生成する（先に pod install 必須）
  def workspace_path
    File.join(project_root, "ios", "#{SCHEME}.xcworkspace")
  end

  desc "証明書/プロファイルを作成しmatchリポへ保存（初回1回だけ・メイン＋拡張の2つ）"
  lane :certs do
    match(type: "appstore", readonly: false, app_identifier: [APP_ID, EXT_ID], api_key: asc_api_key)
  end

  desc "証明書取得→2ターゲット署名→IPAビルド"
  lane :build do
    api_key = asc_api_key
    match(type: "appstore", readonly: true, app_identifier: [APP_ID, EXT_ID], api_key: api_key)

    main_profile = ENV["sigh_#{APP_ID}_appstore_profile-name"] || "match AppStore #{APP_ID}"
    ext_profile  = ENV["sigh_#{EXT_ID}_appstore_profile-name"] || "match AppStore #{EXT_ID}"

    proj = File.join(project_root, "ios", "#{SCHEME}.xcodeproj")

    # prebuild生成projは自動署名・チーム空 → 各ターゲットを手動署名へ書き換え
    update_code_signing_settings(
      use_automatic_signing: false,
      path: proj,
      team_id: ENV["APPLE_TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      profile_name: main_profile,
      targets: [SCHEME]
    )
    update_code_signing_settings(
      use_automatic_signing: false,
      path: proj,
      team_id: ENV["APPLE_TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      profile_name: ext_profile,
      targets: [EXT_TARGET]
    )

    # ビルド番号を自動採番。EAS提出済みの22を必ず超えるようオフセット(+100)。
    # 拡張とメインは同じ CFBundleVersion / CFBundleShortVersionString が必須。
    build_no = ((ENV["GITHUB_RUN_NUMBER"] || "0").to_i + 100).to_s
    set_info_plist_value(
      path: File.join(project_root, "ios", "Bookrest", "Info.plist"),
      key: "CFBundleVersion", value: build_no
    )
    set_info_plist_value(
      path: File.join(project_root, "ios", "BookrestShareExtension", "Info.plist"),
      key: "CFBundleVersion", value: build_no
    )

    gym(
      workspace: workspace_path,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "app.ipa",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        provisioningProfiles: {
          APP_ID => main_profile,
          EXT_ID => ext_profile
        }
      }
    )
  end

  desc "ビルドしてTestFlightへ配信"
  lane :beta do
    build
    pilot(
      api_key: asc_api_key,
      ipa: "build/app.ipa",
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
